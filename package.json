{
  "name": "gitstudio-workspace",
  "private": true,
  "version": "0.0.0",
  "description": "GitStudio — a free, open-source, JetBrains-grade Git suite for VS Code, Cursor, and a native desktop app.",
  "license": "Apache-2.0",
  "homepage": "https://gitstudio.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/GitStudioHQ/gitstudio.git"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "test": "npm run test --workspaces --if-present",
    "check-types": "npm run check-types --workspaces --if-present",
    "check-purity": "bash scripts/check-engine-purity.sh",
    "build": "npm run package --workspace apps/extension",
    "package": "npm run package --workspace apps/extension",
    "watch": "npm run watch --workspace apps/extension"
  },
  "devDependencies": {
    "esbuild": "^0.28.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "dompurify": "3.4.11"
  }
}
