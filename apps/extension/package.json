{
  "name": "gitstudio",
  "displayName": "GitStudio",
  "description": "A free, open-source, JetBrains-grade Git suite for VS Code & Cursor — commit graph, inline blame, file & line history, hunk/line staging, side-by-side diff, 3-pane merge, interactive rebase with a universal Undo safety net, and optional bring-your-own-key AI.",
  "version": "0.1.0",
  "publisher": "gitstudio",
  "license": "Apache-2.0",
  "icon": "media/icon.png",
  "homepage": "https://gitstudio.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/GitStudioHQ/gitstudio.git"
  },
  "bugs": {
    "url": "https://github.com/GitStudioHQ/gitstudio/issues"
  },
  "galleryBanner": {
    "color": "#1E222A",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "keywords": [
    "git",
    "gitlens",
    "git graph",
    "commit graph",
    "blame",
    "git history",
    "git blame",
    "merge",
    "diff",
    "rebase",
    "interactive rebase",
    "staging",
    "cherry-pick",
    "vscode",
    "cursor",
    "source control"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "extensionDependencies": [
    "vscode.git"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "gitstudio",
          "title": "GitStudio",
          "icon": "media/activitybar.svg"
        }
      ]
    },
    "views": {
      "gitstudio": [
        {
          "id": "gitstudio.commits",
          "name": "Commits"
        },
        {
          "id": "gitstudio.branches",
          "name": "Branches"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "gitstudio.commits",
        "when": "!gitstudio.hasRepo",
        "contents": "Open a folder with a Git repository to get started.\nGitStudio shows your commits, branches, remotes, and tags here once a repository is detected.\n[Open Folder](command:vscode.openFolder)"
      }
    ],
    "commands": [
      {
        "command": "gitstudio.showWelcome",
        "title": "Welcome",
        "category": "GitStudio"
      },
      {
        "command": "gitstudio.refreshCommits",
        "title": "Refresh Commits",
        "category": "GitStudio",
        "icon": "$(refresh)"
      },
      {
        "command": "gitstudio.refreshBranches",
        "title": "Refresh Branches",
        "category": "GitStudio",
        "icon": "$(refresh)"
      },
      {
        "command": "gitstudio.copyCommitSha",
        "title": "Copy Commit SHA",
        "category": "GitStudio",
        "icon": "$(copy)"
      },
      {
        "command": "gitstudio.toggleFileBlame",
        "title": "Toggle File Blame",
        "category": "GitStudio",
        "icon": "$(git-commit)"
      },
      {
        "command": "gitstudio.blame.showLineActions",
        "title": "Line Blame Actions",
        "category": "GitStudio"
      },
      {
        "command": "gitstudio.showCommitGraph",
        "title": "Show Commit Graph",
        "category": "GitStudio",
        "icon": "$(git-commit)"
      }
    ],
    "keybindings": [
      {
        "command": "gitstudio.toggleFileBlame",
        "key": "ctrl+shift+g b",
        "mac": "cmd+shift+g b",
        "when": "editorTextFocus"
      }
    ],
    "configuration": {
      "title": "GitStudio",
      "properties": {
        "gitstudio.blame.inlineEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Show inline blame for the current line (author, relative time, and summary) at the end of the line."
        },
        "gitstudio.blame.statusBarEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Show the current line's commit author and age in the status bar."
        },
        "gitstudio.blame.heatmap": {
          "type": "boolean",
          "default": true,
          "description": "Tint full-file blame annotations with a code-age heatmap (recent changes warmer, older changes cooler)."
        }
      }
    },
    "menus": {
      "view/title": [
        {
          "command": "gitstudio.showCommitGraph",
          "when": "view == gitstudio.commits",
          "group": "navigation@1"
        },
        {
          "command": "gitstudio.refreshCommits",
          "when": "view == gitstudio.commits",
          "group": "navigation@2"
        },
        {
          "command": "gitstudio.refreshBranches",
          "when": "view == gitstudio.branches",
          "group": "navigation"
        }
      ],
      "editor/title": [
        {
          "command": "gitstudio.toggleFileBlame",
          "when": "editorTextFocus && gitstudio.hasRepo",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "gitstudio.toggleFileBlame",
          "when": "editorTextFocus && gitstudio.hasRepo"
        },
        {
          "command": "gitstudio.blame.showLineActions",
          "when": "editorTextFocus && gitstudio.hasRepo"
        }
      ],
      "view/item/context": [
        {
          "command": "gitstudio.copyCommitSha",
          "when": "view == gitstudio.commits && viewItem == gitstudio.commit",
          "group": "inline"
        },
        {
          "command": "gitstudio.copyCommitSha",
          "when": "view == gitstudio.commits && viewItem == gitstudio.commit",
          "group": "9_gitstudio@1"
        }
      ]
    }
  },
  "scripts": {
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "node esbuild.js --production",
    "check-types": "tsc --noEmit",
    "test": "tsx --test \"test/**/*.test.ts\"",
    "vscode:prepublish": "npm run package"
  },
  "devDependencies": {
    "@types/node": "^20.19.42",
    "@types/vscode": "1.74.0",
    "esbuild": "^0.28.1",
    "monaco-editor": "^0.55.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vscode-diff": "^3.0.1"
  },
  "dependencies": {
    "@gitstudio/engine": "*",
    "@gitstudio/git-service": "*",
    "@gitstudio/host-bridge": "*",
    "@gitstudio/webview-ui": "*"
  },
  "pricing": "Free",
  "extensionKind": [
    "workspace"
  ],
  "capabilities": {
    "virtualWorkspaces": {
      "supported": false,
      "description": "GitStudio requires a local git repository on disk."
    }
  }
}
