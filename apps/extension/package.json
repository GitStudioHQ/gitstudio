{
  "name": "gitstudio",
  "displayName": "GitStudio",
  "description": "A free, open-source, JetBrains-grade Git suite for VS Code & Cursor — commit graph, inline blame, file & line history, hunk/line staging, side-by-side diff, 3-pane merge, interactive rebase with a universal Undo safety net, and optional bring-your-own-key AI.",
  "version": "0.1.0",
  "publisher": "gitstudio",
  "license": "Apache-2.0",
  "icon": "media/icon.png",
  "homepage": "https://gitstudio.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/GitStudioHQ/gitstudio.git"
  },
  "bugs": {
    "url": "https://github.com/GitStudioHQ/gitstudio/issues"
  },
  "galleryBanner": {
    "color": "#1E222A",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "keywords": [
    "git",
    "gitlens",
    "git graph",
    "commit graph",
    "blame",
    "git history",
    "git blame",
    "merge",
    "diff",
    "rebase",
    "interactive rebase",
    "staging",
    "cherry-pick",
    "vscode",
    "cursor",
    "source control"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "extensionDependencies": [
    "vscode.git"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "gitstudio",
          "title": "GitStudio",
          "icon": "media/activitybar.svg"
        }
      ]
    },
    "views": {
      "gitstudio": [
        {
          "id": "gitstudio.commit",
          "name": "Commit",
          "type": "webview"
        },
        {
          "id": "gitstudio.changes",
          "name": "Changes"
        },
        {
          "id": "gitstudio.commits",
          "name": "Commits"
        },
        {
          "id": "gitstudio.branches",
          "name": "Branches"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "gitstudio.commits",
        "when": "!gitstudio.hasRepo",
        "contents": "Open a folder with a Git repository to get started.\nGitStudio shows your commits, branches, remotes, and tags here once a repository is detected.\n[Open Folder](command:vscode.openFolder)"
      }
    ],
    "customEditors": [
      {
        "viewType": "gitstudio.mergeEditor",
        "displayName": "GitStudio 3-Pane Merge",
        "selector": [
          {
            "filenamePattern": "*"
          }
        ],
        "priority": "option"
      },
      {
        "viewType": "gitstudio.rebaseTodoEditor",
        "displayName": "GitStudio Interactive Rebase",
        "selector": [
          {
            "filenamePattern": "**/git-rebase-todo"
          }
        ],
        "priority": "default"
      }
    ],
    "commands": [
      {
        "command": "gitstudio.showWelcome",
        "title": "Welcome",
        "category": "GitStudio"
      },
      {
        "command": "gitstudio.refreshCommits",
        "title": "Refresh Commits",
        "category": "GitStudio",
        "icon": "$(refresh)"
      },
      {
        "command": "gitstudio.refreshBranches",
        "title": "Refresh Branches",
        "category": "GitStudio",
        "icon": "$(refresh)"
      },
      {
        "command": "gitstudio.copyCommitSha",
        "title": "Copy Commit SHA",
        "category": "GitStudio",
        "icon": "$(copy)"
      },
      {
        "command": "gitstudio.toggleFileBlame",
        "title": "Toggle File Blame",
        "category": "GitStudio",
        "icon": "$(git-commit)"
      },
      {
        "command": "gitstudio.blame.showLineActions",
        "title": "Line Blame Actions",
        "category": "GitStudio"
      },
      {
        "command": "gitstudio.showCommitGraph",
        "title": "Show Commit Graph",
        "category": "GitStudio",
        "icon": "$(git-commit)"
      },
      {
        "command": "gitstudio.showLineHistory",
        "title": "Show Line History",
        "category": "GitStudio",
        "icon": "$(history)"
      },
      {
        "command": "gitstudio.openChanges",
        "title": "Open Changes (vs HEAD)",
        "category": "GitStudio",
        "icon": "$(git-compare)"
      },
      {
        "command": "gitstudio.openFileAtRevision",
        "title": "Open File at Revision…",
        "category": "GitStudio",
        "icon": "$(history)"
      },
      {
        "command": "gitstudio.revisionNavigateBack",
        "title": "Revision: Step to Older",
        "category": "GitStudio",
        "icon": "$(arrow-left)"
      },
      {
        "command": "gitstudio.revisionNavigateForward",
        "title": "Revision: Step to Newer",
        "category": "GitStudio",
        "icon": "$(arrow-right)"
      },
      {
        "command": "gitstudio.showReflog",
        "title": "Show Reflog (Time Machine)",
        "category": "GitStudio",
        "icon": "$(history)"
      },
      {
        "command": "gitstudio.resolveInMergeEditor",
        "title": "Resolve in Merge Editor",
        "category": "GitStudio",
        "icon": "$(git-merge)"
      },
      {
        "command": "gitstudio.compare",
        "title": "Compare File…",
        "category": "GitStudio",
        "icon": "$(git-compare)"
      },
      {
        "command": "gitstudio.changes.refresh",
        "title": "Refresh Changes",
        "category": "GitStudio",
        "icon": "$(refresh)"
      },
      {
        "command": "gitstudio.changes.stageFile",
        "title": "Stage",
        "category": "GitStudio",
        "icon": "$(add)"
      },
      {
        "command": "gitstudio.changes.unstageFile",
        "title": "Unstage",
        "category": "GitStudio",
        "icon": "$(remove)"
      },
      {
        "command": "gitstudio.changes.discardFile",
        "title": "Discard Changes",
        "category": "GitStudio",
        "icon": "$(discard)"
      },
      {
        "command": "gitstudio.changes.stageAll",
        "title": "Stage All",
        "category": "GitStudio",
        "icon": "$(add)"
      },
      {
        "command": "gitstudio.changes.unstageAll",
        "title": "Unstage All",
        "category": "GitStudio",
        "icon": "$(remove)"
      },
      {
        "command": "gitstudio.changes.discardAll",
        "title": "Discard All",
        "category": "GitStudio",
        "icon": "$(discard)"
      },
      {
        "command": "gitstudio.stageSelectedLines",
        "title": "Stage Selected Lines",
        "category": "GitStudio",
        "icon": "$(add)"
      },
      {
        "command": "gitstudio.unstageSelectedLines",
        "title": "Unstage Selected Lines",
        "category": "GitStudio",
        "icon": "$(remove)"
      },
      {
        "command": "gitstudio.stageHunk",
        "title": "Stage Hunk",
        "category": "GitStudio",
        "icon": "$(add)"
      },
      {
        "command": "gitstudio.unstageHunk",
        "title": "Unstage Hunk",
        "category": "GitStudio",
        "icon": "$(remove)"
      },
      {
        "command": "gitstudio.startInteractiveRebase",
        "title": "Start Interactive Rebase…",
        "category": "GitStudio",
        "icon": "$(git-merge)"
      },
      {
        "command": "gitstudio.abortRebase",
        "title": "Abort Rebase",
        "category": "GitStudio",
        "icon": "$(stop)"
      },
      {
        "command": "gitstudio.undo",
        "title": "Undo Last Git Operation",
        "category": "GitStudio",
        "icon": "$(discard)"
      },
      {
        "command": "gitstudio.showUndoHistory",
        "title": "Show Undo History",
        "category": "GitStudio",
        "icon": "$(history)"
      },
      {
        "command": "gitstudio.resetToCommit",
        "title": "Reset Current Branch to Here…",
        "category": "GitStudio",
        "icon": "$(discard)"
      }
    ],
    "keybindings": [
      {
        "command": "gitstudio.toggleFileBlame",
        "key": "ctrl+shift+g b",
        "mac": "cmd+shift+g b",
        "when": "editorTextFocus"
      },
      {
        "command": "gitstudio.showLineHistory",
        "key": "ctrl+shift+g h",
        "mac": "cmd+shift+g h",
        "when": "editorTextFocus && gitstudio.hasRepo"
      },
      {
        "command": "gitstudio.stageSelectedLines",
        "key": "ctrl+k ctrl+s",
        "mac": "cmd+k cmd+s",
        "when": "editorTextFocus && gitstudio.hasRepo"
      },
      {
        "command": "gitstudio.unstageSelectedLines",
        "key": "ctrl+k ctrl+u",
        "mac": "cmd+k cmd+u",
        "when": "editorTextFocus && gitstudio.hasRepo"
      },
      {
        "command": "gitstudio.undo",
        "key": "ctrl+alt+z",
        "mac": "cmd+alt+z",
        "when": "gitstudio.hasRepo && !editorTextFocus"
      }
    ],
    "configuration": {
      "title": "GitStudio",
      "properties": {
        "gitstudio.blame.inlineEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Show inline blame for the current line (author, relative time, and summary) at the end of the line."
        },
        "gitstudio.blame.statusBarEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Show the current line's commit author and age in the status bar."
        },
        "gitstudio.blame.heatmap": {
          "type": "boolean",
          "default": true,
          "description": "Tint full-file blame annotations with a code-age heatmap (recent changes warmer, older changes cooler)."
        },
        "gitstudio.merge.autoOpen": {
          "type": "boolean",
          "default": true,
          "description": "When a file becomes conflicted (during a merge, rebase, or cherry-pick), automatically open it in the GitStudio 3-pane merge editor."
        },
        "gitstudio.commit.signoffByDefault": {
          "type": "boolean",
          "default": false,
          "description": "Enable the Sign-off toggle by default in the GitStudio commit box (adds a Signed-off-by trailer)."
        }
      }
    },
    "menus": {
      "view/title": [
        {
          "command": "gitstudio.showCommitGraph",
          "when": "view == gitstudio.commits",
          "group": "navigation@1"
        },
        {
          "command": "gitstudio.refreshCommits",
          "when": "view == gitstudio.commits",
          "group": "navigation@2"
        },
        {
          "command": "gitstudio.refreshBranches",
          "when": "view == gitstudio.branches",
          "group": "navigation"
        },
        {
          "command": "gitstudio.changes.stageAll",
          "when": "view == gitstudio.changes",
          "group": "navigation@1"
        },
        {
          "command": "gitstudio.changes.unstageAll",
          "when": "view == gitstudio.changes",
          "group": "navigation@2"
        },
        {
          "command": "gitstudio.changes.refresh",
          "when": "view == gitstudio.changes",
          "group": "navigation@3"
        }
      ],
      "editor/title": [
        {
          "command": "gitstudio.openChanges",
          "when": "gitstudio.hasRepo && resourceScheme == file",
          "group": "navigation@-1"
        },
        {
          "command": "gitstudio.resolveInMergeEditor",
          "when": "gitstudio.hasRepo && resourceScheme == file",
          "group": "navigation@-2"
        },
        {
          "command": "gitstudio.toggleFileBlame",
          "when": "editorTextFocus && gitstudio.hasRepo",
          "group": "navigation"
        }
      ],
      "scm/resourceState/context": [
        {
          "command": "gitstudio.resolveInMergeEditor",
          "when": "scmProvider == git && scmResourceGroup == merge",
          "group": "navigation@1"
        }
      ],
      "explorer/context": [
        {
          "command": "gitstudio.compare",
          "when": "gitstudio.hasRepo && resourceScheme == file && !explorerResourceIsFolder",
          "group": "3_compare@10"
        }
      ],
      "editor/context": [
        {
          "command": "gitstudio.showLineHistory",
          "when": "editorTextFocus && gitstudio.hasRepo",
          "group": "navigation@10"
        },
        {
          "command": "gitstudio.openFileAtRevision",
          "when": "editorTextFocus && gitstudio.hasRepo",
          "group": "navigation@11"
        },
        {
          "command": "gitstudio.stageSelectedLines",
          "when": "editorTextFocus && gitstudio.hasRepo && resourceScheme == file",
          "group": "2_gitstudio@1"
        },
        {
          "command": "gitstudio.unstageSelectedLines",
          "when": "editorTextFocus && gitstudio.hasRepo && resourceScheme == file",
          "group": "2_gitstudio@2"
        },
        {
          "command": "gitstudio.stageHunk",
          "when": "editorTextFocus && gitstudio.hasRepo && resourceScheme == file",
          "group": "2_gitstudio@3"
        },
        {
          "command": "gitstudio.unstageHunk",
          "when": "editorTextFocus && gitstudio.hasRepo && resourceScheme == file",
          "group": "2_gitstudio@4"
        }
      ],
      "commandPalette": [
        {
          "command": "gitstudio.toggleFileBlame",
          "when": "editorTextFocus && gitstudio.hasRepo"
        },
        {
          "command": "gitstudio.blame.showLineActions",
          "when": "editorTextFocus && gitstudio.hasRepo"
        },
        {
          "command": "gitstudio.showLineHistory",
          "when": "editorTextFocus && gitstudio.hasRepo"
        },
        {
          "command": "gitstudio.openChanges",
          "when": "gitstudio.hasRepo && resourceScheme == file"
        },
        {
          "command": "gitstudio.openFileAtRevision",
          "when": "editorTextFocus && gitstudio.hasRepo"
        },
        {
          "command": "gitstudio.revisionNavigateBack",
          "when": "gitstudio.hasRepo"
        },
        {
          "command": "gitstudio.revisionNavigateForward",
          "when": "gitstudio.hasRepo"
        },
        {
          "command": "gitstudio.showReflog",
          "when": "gitstudio.hasRepo"
        },
        {
          "command": "gitstudio.resolveInMergeEditor",
          "when": "gitstudio.hasRepo && resourceScheme == file"
        },
        {
          "command": "gitstudio.compare",
          "when": "gitstudio.hasRepo && resourceScheme == file"
        },
        {
          "command": "gitstudio.stageSelectedLines",
          "when": "editorTextFocus && gitstudio.hasRepo"
        },
        {
          "command": "gitstudio.unstageSelectedLines",
          "when": "editorTextFocus && gitstudio.hasRepo"
        },
        {
          "command": "gitstudio.stageHunk",
          "when": "editorTextFocus && gitstudio.hasRepo"
        },
        {
          "command": "gitstudio.unstageHunk",
          "when": "editorTextFocus && gitstudio.hasRepo"
        },
        {
          "command": "gitstudio.changes.refresh",
          "when": "gitstudio.hasRepo"
        },
        {
          "command": "gitstudio.changes.stageFile",
          "when": "false"
        },
        {
          "command": "gitstudio.changes.unstageFile",
          "when": "false"
        },
        {
          "command": "gitstudio.changes.discardFile",
          "when": "false"
        },
        {
          "command": "gitstudio.changes.openDiff",
          "when": "false"
        },
        {
          "command": "gitstudio.changes.stageAll",
          "when": "gitstudio.hasRepo"
        },
        {
          "command": "gitstudio.changes.unstageAll",
          "when": "gitstudio.hasRepo"
        },
        {
          "command": "gitstudio.changes.discardAll",
          "when": "gitstudio.hasRepo"
        },
        {
          "command": "gitstudio.startInteractiveRebase",
          "when": "gitstudio.hasRepo"
        },
        {
          "command": "gitstudio.abortRebase",
          "when": "gitstudio.hasRepo"
        },
        {
          "command": "gitstudio.undo",
          "when": "gitstudio.hasRepo"
        },
        {
          "command": "gitstudio.showUndoHistory",
          "when": "gitstudio.hasRepo"
        },
        {
          "command": "gitstudio.resetToCommit",
          "when": "false"
        }
      ],
      "view/item/context": [
        {
          "command": "gitstudio.copyCommitSha",
          "when": "view == gitstudio.commits && viewItem == gitstudio.commit",
          "group": "inline"
        },
        {
          "command": "gitstudio.copyCommitSha",
          "when": "view == gitstudio.commits && viewItem == gitstudio.commit",
          "group": "9_gitstudio@1"
        },
        {
          "command": "gitstudio.startInteractiveRebase",
          "when": "view == gitstudio.commits && viewItem == gitstudio.commit",
          "group": "1_gitstudio@1"
        },
        {
          "command": "gitstudio.resetToCommit",
          "when": "view == gitstudio.commits && viewItem == gitstudio.commit",
          "group": "1_gitstudio@2"
        },
        {
          "command": "gitstudio.changes.stageFile",
          "when": "view == gitstudio.changes && (viewItem == gitstudio.change.unstaged || viewItem == gitstudio.change.merge)",
          "group": "inline@1"
        },
        {
          "command": "gitstudio.changes.discardFile",
          "when": "view == gitstudio.changes && viewItem == gitstudio.change.unstaged",
          "group": "inline@2"
        },
        {
          "command": "gitstudio.changes.unstageFile",
          "when": "view == gitstudio.changes && viewItem == gitstudio.change.staged",
          "group": "inline@1"
        },
        {
          "command": "gitstudio.changes.stageFile",
          "when": "view == gitstudio.changes && (viewItem == gitstudio.change.unstaged || viewItem == gitstudio.change.merge)",
          "group": "1_gitstudio@1"
        },
        {
          "command": "gitstudio.changes.unstageFile",
          "when": "view == gitstudio.changes && viewItem == gitstudio.change.staged",
          "group": "1_gitstudio@1"
        },
        {
          "command": "gitstudio.changes.discardFile",
          "when": "view == gitstudio.changes && viewItem == gitstudio.change.unstaged",
          "group": "1_gitstudio@2"
        },
        {
          "command": "gitstudio.changes.stageAll",
          "when": "view == gitstudio.changes && (viewItem == gitstudio.changeGroup.unstaged || viewItem == gitstudio.changeGroup.merge)",
          "group": "inline@1"
        },
        {
          "command": "gitstudio.changes.discardAll",
          "when": "view == gitstudio.changes && viewItem == gitstudio.changeGroup.unstaged",
          "group": "inline@2"
        },
        {
          "command": "gitstudio.changes.unstageAll",
          "when": "view == gitstudio.changes && viewItem == gitstudio.changeGroup.staged",
          "group": "inline@1"
        }
      ]
    }
  },
  "scripts": {
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "node esbuild.js --production",
    "check-types": "tsc --noEmit",
    "test": "tsx --test \"test/**/*.test.ts\"",
    "vscode:prepublish": "npm run package"
  },
  "devDependencies": {
    "@types/node": "^20.19.42",
    "@types/vscode": "1.74.0",
    "esbuild": "^0.28.1",
    "monaco-editor": "^0.55.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vscode-diff": "^3.0.1"
  },
  "dependencies": {
    "@gitstudio/engine": "*",
    "@gitstudio/git-service": "*",
    "@gitstudio/host-bridge": "*",
    "@gitstudio/webview-ui": "*"
  },
  "pricing": "Free",
  "extensionKind": [
    "workspace"
  ],
  "capabilities": {
    "virtualWorkspaces": {
      "supported": false,
      "description": "GitStudio requires a local git repository on disk."
    }
  }
}
