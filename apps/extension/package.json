{
  "name": "gitstudio",
  "displayName": "GitStudio — JetBrains-style Git Graph, Blame & Merge",
  "description": "Free, open-source Git GUI & commit graph for VS Code and Cursor. Git Studio brings a JetBrains-style Git workflow into the editor — inline blame, file history, hunk & line staging, 3-pane merge, interactive rebase with universal Undo, stash/shelf, worktrees, and in-editor GitHub PRs. A free alternative to GitLens, GitKraken & Sourcetree.",
  "version": "1.2.0",
  "publisher": "gitstudio",
  "license": "Apache-2.0",
  "icon": "media/icon.png",
  "homepage": "https://gitstudio.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/GitStudioHQ/gitstudio.git"
  },
  "bugs": {
    "url": "https://github.com/GitStudioHQ/gitstudio/issues"
  },
  "galleryBanner": {
    "color": "#1A1726",
    "theme": "dark"
  },
  "qna": "marketplace",
  "badges": [
    {
      "url": "https://img.shields.io/github/actions/workflow/status/GitStudioHQ/gitstudio/ci.yml?branch=main&label=CI",
      "href": "https://github.com/GitStudioHQ/gitstudio/actions/workflows/ci.yml",
      "description": "CI build status"
    },
    {
      "url": "https://img.shields.io/visual-studio-marketplace/v/gitstudio.gitstudio?label=Marketplace",
      "href": "https://marketplace.visualstudio.com/items?itemName=gitstudio.gitstudio",
      "description": "Visual Studio Marketplace version"
    },
    {
      "url": "https://img.shields.io/github/license/GitStudioHQ/gitstudio",
      "href": "https://github.com/GitStudioHQ/gitstudio/blob/main/LICENSE",
      "description": "Apache-2.0 license"
    }
  ],
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "SCM Providers",
    "Visualization",
    "AI"
  ],
  "keywords": [
    "gitstudio",
    "git-studio",
    "gitlens alternative",
    "jetbrains",
    "intellij",
    "pycharm",
    "git gui",
    "git client",
    "commit graph",
    "git graph",
    "interactive rebase",
    "merge conflict",
    "merge editor",
    "worktree",
    "cherry-pick",
    "reflog",
    "stash",
    "shelf",
    "git blame",
    "file history",
    "staging",
    "branch manager",
    "branch compare",
    "pull request",
    "github",
    "ai commit message",
    "source control",
    "scm",
    "git",
    "cursor"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "extensionDependencies": [
    "vscode.git"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "gitstudio",
          "title": "GitStudio",
          "icon": "media/activitybar.svg"
        }
      ]
    },
    "views": {
      "gitstudio": [
        {
          "id": "gitstudio.commit",
          "name": "Changes",
          "type": "webview"
        },
        {
          "id": "gitstudio.commits",
          "name": "Commits",
          "type": "webview"
        },
        {
          "id": "gitstudio.stashes",
          "name": "Stashes",
          "type": "webview"
        },
        {
          "id": "gitstudio.worktrees",
          "name": "Worktrees"
        },
        {
          "id": "gitstudio.pullRequests",
          "name": "Pull Requests"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "gitstudio.worktrees",
        "when": "gitstudio.hasRepo",
        "contents": "Work on multiple branches at once with linked worktrees.\n[New Worktree](command:gitstudio.worktree.add)"
      },
      {
        "view": "gitstudio.pullRequests",
        "when": "gitstudio.hasRepo && !gitstudio.github.connected",
        "contents": "Connect GitHub to review pull requests.\nSign in once with VS Code's built-in GitHub account to list, check out, review, merge, and create pull requests without leaving the editor.\n[Sign in to GitHub](command:gitstudio.pr.signIn)"
      }
    ],
    "customEditors": [
      {
        "viewType": "gitstudio.mergeEditor",
        "displayName": "GitStudio 3-Pane Merge",
        "selector": [
          {
            "filenamePattern": "*"
          }
        ],
        "priority": "option"
      },
      {
        "viewType": "gitstudio.rebaseTodoEditor",
        "displayName": "GitStudio Interactive Rebase",
        "selector": [
          {
            "filenamePattern": "**/git-rebase-todo"
          }
        ],
        "priority": "default"
      }
    ],
