    "keybindings": [
      {
        "command": "gitstudio.toggleFileBlame",
        "key": "ctrl+alt+g b",
        "mac": "cmd+alt+g b",
        "when": "editorTextFocus"
      },
      {
        "command": "gitstudio.showLineHistory",
        "key": "ctrl+alt+g h",
        "mac": "cmd+alt+g h",
        "when": "editorTextFocus"
      },
      {
        "command": "gitstudio.openChanges",
        "key": "ctrl+alt+g d",
        "mac": "cmd+alt+g d",
        "when": "editorTextFocus"
      },
      {
        "command": "gitstudio.stageSelectedLines",
        "key": "ctrl+alt+g s",
        "mac": "cmd+alt+g s",
        "when": "editorTextFocus && editorHasSelection"
      },
      {
        "command": "gitstudio.unstageSelectedLines",
        "key": "ctrl+alt+g u",
        "mac": "cmd+alt+g u",
        "when": "editorTextFocus && editorHasSelection"
      },
      {
        "command": "gitstudio.undo",
        "key": "ctrl+alt+g z",
        "mac": "cmd+alt+g z"
      }
    ],
    "configuration": {
      "title": "GitStudio",
      "properties": {
        "gitstudio.blame.inlineEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Show inline blame for the current line (author, relative time, and summary) at the end of the line."
        },
        "gitstudio.blame.statusBarEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Show the current line's commit author and age in the status bar."
        },
        "gitstudio.blame.heatmap": {
          "type": "boolean",
          "default": true,
          "description": "Tint full-file blame annotations with a code-age heatmap (recent changes warmer, older changes cooler)."
        },
        "gitstudio.merge.autoOpen": {
          "type": "boolean",
          "default": true,
          "description": "When a file becomes conflicted (during a merge, rebase, or cherry-pick), automatically open it in the GitStudio 3-pane merge editor."
        },
        "gitstudio.commit.signoffByDefault": {
          "type": "boolean",
          "default": false,
          "description": "Enable the Sign-off toggle by default in the GitStudio commit box (adds a Signed-off-by trailer)."
        },
        "gitstudio.push.forceWithLease": {
          "type": "boolean",
          "default": true,
          "description": "When force-pushing from GitStudio, use the safer --force-with-lease (which refuses to overwrite remote work you haven't seen) instead of a raw --force."
        },
        "gitstudio.ai.provider": {
          "type": "string",
          "enum": [
            "auto",
            "copilot",
            "anthropic",
            "openai",
            "off"
          ],
          "enumDescriptions": [
            "Prefer the zero-key VS Code Language Model (GitHub Copilot / Cursor) when available; otherwise Anthropic (if a key is set), then an OpenAI-compatible endpoint (if a model is configured).",
            "Use the VS Code Language Model API — GitHub Copilot or Cursor's models, with no key. Pick a specific model via “GitStudio: Select AI Model…”.",
            "Use Anthropic directly (requires an API key set via GitStudio: Set AI API Key).",
            "Use any OpenAI-compatible endpoint — OpenAI, Codex, OpenRouter, or a local server (Ollama / LM Studio). Configure the base URL and model below; a key is optional for local servers.",
            "Disable all GitBrain AI features."
          ],
          "default": "auto",
          "markdownDescription": "Which provider GitBrain uses for optional AI features. AI is off until a provider is available; it never gates or breaks Git operations. Use **GitStudio: Select AI Model…** for a guided picker."
        },
        "gitstudio.ai.openai.baseUrl": {
          "type": "string",
          "default": "https://api.openai.com/v1",
          "markdownDescription": "Base URL for the OpenAI-compatible endpoint (`/chat/completions` is appended). Examples: `https://api.openai.com/v1` (OpenAI), `https://openrouter.ai/api/v1` (OpenRouter), `http://localhost:11434/v1` (Ollama), `http://localhost:1234/v1` (LM Studio)."
        },
        "gitstudio.ai.openai.modelFast": {
          "type": "string",
          "default": "gpt-4o-mini",
          "description": "OpenAI-compatible model ID for fast/cheap tasks (commit messages). For a local server use its model name, e.g. llama3.1 or qwen2.5-coder."
        },
        "gitstudio.ai.openai.modelMid": {
          "type": "string",
          "default": "gpt-4o-mini",
          "description": "OpenAI-compatible model ID for mid-tier tasks (explain diff, summaries)."
        },
        "gitstudio.ai.openai.modelDeep": {
          "type": "string",
          "default": "gpt-4o",
          "description": "OpenAI-compatible model ID for opt-in deep reasoning."
        },
        "gitstudio.ai.anthropicModelFast": {
          "type": "string",
          "default": "claude-haiku-4-5",
          "description": "Anthropic model ID for fast/cheap tasks (commit messages)."
        },
        "gitstudio.ai.anthropicModelMid": {
          "type": "string",
          "default": "claude-sonnet-4-6",
          "description": "Anthropic model ID for mid-tier tasks (explain diff, summaries)."
        },
        "gitstudio.ai.anthropicModelDeep": {
          "type": "string",
          "default": "claude-opus-4-8",
          "description": "Anthropic model ID for opt-in deep reasoning."
        },
        "gitstudio.ai.commitStyle": {
          "type": "string",
          "enum": [
            "conventional",
            "concise",
            "descriptive"
          ],
          "enumDescriptions": [
            "Conventional Commits (type(scope): summary), optional body.",
            "A single concise subject line, no body.",
            "Imperative subject plus a short explanatory body."
          ],
          "default": "conventional",
          "description": "How GitBrain styles generated commit messages."
        },
        "gitstudio.ai.reviewPrompt": {
          "type": "string",
          "editPresentation": "multilineText",
          "default": "",
          "markdownDescription": "Custom system prompt for **Review Changes (AI)**. Leave empty to use GitStudio's built-in code-review prompt. Set your own to steer the review (e.g. focus areas, house style, output format)."
        },
        "gitstudio.ai.cliAgent": {
          "type": "string",
          "enum": [
            "",
            "claude-code",
            "codex",
            "gemini-cli"
          ],
          "enumDescriptions": [
            "No local agent.",
            "Claude Code CLI (`claude`).",
            "OpenAI Codex CLI (`codex`).",
            "Gemini CLI (`gemini`)."
          ],
          "default": "",
          "description": "The local agent CLI to drive (uses its own login, no API key). Set via the GitStudio · AI panel; used when the provider is a local agent."
        },
        "gitstudio.ai.cliModel": {
          "type": "string",
          "default": "",
          "description": "Optional model override passed to the local agent CLI (blank = the CLI's default)."
        },
        "gitstudio.pr.defaultMergeMethod": {
          "type": "string",
          "enum": [
            "merge",
            "squash",
            "rebase"
          ],
          "enumDescriptions": [
            "Create a merge commit.",
            "Squash the PR's commits into one and merge.",
            "Rebase the PR's commits onto the base and merge."
          ],
          "default": "squash",
          "description": "Default method offered first when merging a pull request."
        },
        "gitstudio.errorReporting.enabled": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Send **anonymous, scrubbed crash reports** when a GitStudio command fails, so we can find and fix bugs during the beta without waiting for someone to file a report. No identity, repo contents, file names, commit messages, branch names, or remotes are ever collected — only the shape of a failure (error type/message/stack or the failed operation), tagged with a random install id and your OS/editor version. Reports are also gated by VS Code's global `telemetry.telemetryLevel`: set that to `off` to disable regardless of this toggle. Turn this off to opt out entirely."
        },
        "gitstudio.errorReporting.endpoint": {
          "type": "string",
          "default": "https://gitstudio.dev/api/errors",
          "markdownDescription": "Collector URL that anonymous crash reports are POSTed to as a plain JSON body. Defaults to GitStudio's collector; point it at any endpoint you control, or **leave it blank to disable sending entirely**. If unreachable, reporting silently no-ops."
        }
      }
    },
    "walkthroughs": [
      {
        "id": "gitstudio.gettingStarted",
        "title": "Get Started with GitStudio",
        "description": "A free, JetBrains-grade Git suite — commit graph, blame, history, hunk staging, 3-pane merge, interactive rebase with Undo, and optional BYO-key AI. Take the tour.",
        "when": "true",
        "steps": [
          {
            "id": "gitstudio.walkthrough.graph",
            "title": "Browse your history in the commit graph",
            "description": "Your history as a live, virtualized commit graph — right in the **Commits** view in the sidebar, or full-screen in an editor tab. Colored lanes, ref chips and authorship (never a flat list); right-click any commit to checkout, cherry-pick, branch, or reset, and compare any two branches.\n[Open Commit Graph](command:gitstudio.showCommitGraph)\nTip: the graph lives in the **Commits** view at the top of the GitStudio sidebar — no need to leave it.",
            "media": {
              "image": {
                "light": "media/wordmark-light.png",
                "dark": "media/wordmark-dark.png",
                "hc": "media/wordmark-dark.png"
              },
              "altText": "GitStudio"
            },
            "completionEvents": [
              "onCommand:gitstudio.showCommitGraph"
            ]
          },
          {
            "id": "gitstudio.walkthrough.blame",
            "title": "Turn on inline blame",
            "description": "Ambient, native-feeling authorship: who last changed the current line and when, inline and in the status bar. Toggle full-file annotations with a code-age heatmap.\n[Toggle File Blame](command:gitstudio.toggleFileBlame)\nShortcut: __Ctrl/Cmd+Alt+G B__ in any editor.",
            "media": {
              "image": {
                "light": "media/wordmark-light.png",
                "dark": "media/wordmark-dark.png",
                "hc": "media/wordmark-dark.png"
              },
              "altText": "GitStudio"
            },
            "completionEvents": [
              "onCommand:gitstudio.toggleFileBlame"
            ]
          },
          {
            "id": "gitstudio.walkthrough.stage",
            "title": "Stage a hunk & commit",
            "description": "Stage by hunk or even by line, then commit from the GitStudio commit box (Amend, Sign-off, author override, Commit & Push). When AI is on, the ✨ button drafts a message from your staged diff.\n[Open the Changes view](command:workbench.view.extension.gitstudio)\nShortcut: select lines and press __Ctrl/Cmd+Alt+G S__ to stage them.",
            "media": {
              "image": {
                "light": "media/wordmark-light.png",
                "dark": "media/wordmark-dark.png",
                "hc": "media/wordmark-dark.png"
              },
              "altText": "GitStudio"
            },
            "completionEvents": [
              "onCommand:gitstudio.stageHunk",
              "onCommand:gitstudio.stageSelectedLines"
            ]
          },
          {
            "id": "gitstudio.walkthrough.history",
            "title": "Explore file & line history",
            "description": "Step through how a file — or a single line — evolved over time, with revision navigation and a reflog time-machine for recovery.\n[Show Line History](command:gitstudio.showLineHistory)\nShortcut: __Ctrl/Cmd+Alt+G H__ on the current line.",
            "media": {
              "image": {
                "light": "media/wordmark-light.png",
                "dark": "media/wordmark-dark.png",
                "hc": "media/wordmark-dark.png"
              },
              "altText": "GitStudio"
            },
            "completionEvents": [
              "onCommand:gitstudio.showLineHistory",
              "onCommand:gitstudio.showReflog"
            ]
          },
          {
            "id": "gitstudio.walkthrough.merge",
            "title": "Resolve conflicts in the 3-pane editor",
            "description": "When a merge, rebase, or cherry-pick conflicts, GitStudio opens a JetBrains-style three-pane editor — yours, the result, and theirs — with one-click accept ribbons. Interactive rebase gets the same care, wrapped in a universal, reflog-powered Undo.\n[Start Interactive Rebase](command:gitstudio.startInteractiveRebase)\nMade a mistake? __Undo Last Git Operation__ (Ctrl/Cmd+Alt+G Z) reverses it.",
            "media": {
              "image": {
                "light": "media/wordmark-light.png",
                "dark": "media/wordmark-dark.png",
                "hc": "media/wordmark-dark.png"
              },
              "altText": "GitStudio"
            },
            "completionEvents": [
              "onCommand:gitstudio.startInteractiveRebase",
              "onCommand:gitstudio.resolveInMergeEditor"
            ]
          },
          {
            "id": "gitstudio.walkthrough.connect",
            "title": "Connect GitHub & set up GitBrain (optional)",
            "description": "Sign in once with VS Code's built-in GitHub account to list, check out, review, merge, and create pull requests in-editor. GitBrain AI is optional and bring-your-own-key — set an Anthropic key (or use Copilot's model) for commit messages, explain-this-diff, and summaries. It's off until you turn it on and never gates a Git operation.\n[Sign in to GitHub](command:gitstudio.pr.signIn)\n[Set AI API Key](command:gitstudio.ai.setApiKey)",
            "media": {
              "image": {
                "light": "media/wordmark-light.png",
                "dark": "media/wordmark-dark.png",
                "hc": "media/wordmark-dark.png"
              },
              "altText": "GitStudio"
            },
            "completionEvents": [
              "onCommand:gitstudio.pr.signIn",
              "onCommand:gitstudio.ai.setApiKey"
            ]
          }
        ]
      }
    ],
